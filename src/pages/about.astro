---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "About Me";

const identity = {
	firstName: "SnakeDoc",
	country: "Vietnam",
	occupation: "Programing Instructor",
	hobbies: ["programming", "gaming", "hiking"]
};

const skills = ["Python", "C#", "JS", "HTML", "CSS", "Astro", "Unity", "Pygame", "PyQt"];

const skillColor = "crimson";
const fontWeight = "bold";
const textCase = "uppercase";
---
<BaseLayout pageTitle={pageTitle}>
	<h2>... and my new website built with Astro.</h2>

	<p>I am working on building a blog using the Astro framework.</p>
	<p>This site will update as i learn more about Astros features.</p>

	<p>Here are a few facts about me:</p>
	<ul>
		<li>My name is {identity.firstName}.</li>
		<li>I live in {identity.country} and i work as a {identity.occupation}.</li>
		<li>My Hobbies are:</li>
		<ul>
			{identity.hobbies.length >= 2 &&
				identity.hobbies.map((hobby) => <li>{hobby}</li>)
			}
		</ul>
	</ul>

	<p>My skills are:</p>
	<ul>
		{skills.map((skill) => <li class="skill">{skill}</li>)}
	  </ul>


	<!-- Page-specific Styles -->
	<style define:vars={{skillColor, fontWeight, textCase}}>
		.skill {
			color: var(--skillColor);
			font-weight: var(--fontWeight);
			text-transform: var(--textCase);
		}
	</style>


	<!-- Styles that must affect layout elements (like the h1) -->
	<style is:global>
		h1 {
			color: purple;
			font-size: 4rem;
		}
	</style>
</BaseLayout>


	  





